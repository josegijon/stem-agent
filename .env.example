# =========================================================
# OpenAI API & Models
# =========================================================

OPENAI_API_KEY=your_openai_api_key_here

# Model for reasoning-heavy tasks (STEM phases)
OPENAI_MODEL_DEEP=o1-mini

# Model for fast iterations (ReAct loop, web search)
OPENAI_MODEL_FAST=gpt-4o-mini

# =========================================================
# Agent Configuration
# =========================================================

# Target domain for agent self-specialization
STEM_DOMAIN=Technical Research

# Maximum number of steps allowed in the ReAct loop
# Prevents infinite loops and runaway executions
REACT_MAX_STEPS=8

# =========================================================
# Evaluation / Benchmark
# =========================================================

# Number of times the benchmark test suite is executed
# Higher values improve reliability but increase runtime
BENCHMARK_RUNS=3

# =========================================================
# Logging & Debugging
# =========================================================

# Log level for file output (logs/agent.log)
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Enable console logging
# Note: May interfere with UI rendering; use for development only
DEBUG=False